{
  "@context": {
    "@vocab": "https://schema.org/",
    "databricks": "https://docs.databricks.com/api/workspace/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "Cluster": {
      "@id": "databricks:clusters",
      "@context": {
        "cluster_id": {
          "@id": "databricks:clusters#cluster_id",
          "@type": "xsd:string"
        },
        "cluster_name": {
          "@id": "databricks:clusters#cluster_name",
          "@type": "xsd:string"
        },
        "spark_version": {
          "@id": "databricks:clusters#spark_version",
          "@type": "xsd:string"
        },
        "node_type_id": {
          "@id": "databricks:clusters#node_type_id",
          "@type": "xsd:string"
        },
        "driver_node_type_id": {
          "@id": "databricks:clusters#driver_node_type_id",
          "@type": "xsd:string"
        },
        "num_workers": {
          "@id": "databricks:clusters#num_workers",
          "@type": "xsd:integer"
        },
        "autoscale": {
          "@id": "databricks:clusters#autoscale",
          "@context": {
            "min_workers": {
              "@id": "databricks:clusters#min_workers",
              "@type": "xsd:integer"
            },
            "max_workers": {
              "@id": "databricks:clusters#max_workers",
              "@type": "xsd:integer"
            }
          }
        },
        "state": {
          "@id": "databricks:clusters#state",
          "@type": "xsd:string"
        },
        "state_message": {
          "@id": "databricks:clusters#state_message",
          "@type": "xsd:string"
        },
        "start_time": {
          "@id": "databricks:clusters#start_time",
          "@type": "xsd:long"
        },
        "terminated_time": {
          "@id": "databricks:clusters#terminated_time",
          "@type": "xsd:long"
        },
        "last_activity_time": {
          "@id": "databricks:clusters#last_activity_time",
          "@type": "xsd:long"
        },
        "creator_user_name": {
          "@id": "dcterms:creator",
          "@type": "xsd:string"
        },
        "cluster_source": {
          "@id": "databricks:clusters#cluster_source",
          "@type": "xsd:string"
        },
        "spark_conf": {
          "@id": "databricks:clusters#spark_conf",
          "@type": "@json"
        },
        "custom_tags": {
          "@id": "databricks:clusters#custom_tags",
          "@type": "@json"
        },
        "autotermination_minutes": {
          "@id": "databricks:clusters#autotermination_minutes",
          "@type": "xsd:integer"
        },
        "enable_elastic_disk": {
          "@id": "databricks:clusters#enable_elastic_disk",
          "@type": "xsd:boolean"
        },
        "instance_pool_id": {
          "@id": "databricks:clusters#instance_pool_id",
          "@type": "xsd:string"
        },
        "policy_id": {
          "@id": "databricks:clusters#policy_id",
          "@type": "xsd:string"
        },
        "data_security_mode": {
          "@id": "databricks:clusters#data_security_mode",
          "@type": "xsd:string"
        },
        "runtime_engine": {
          "@id": "databricks:clusters#runtime_engine",
          "@type": "xsd:string"
        }
      }
    },

    "Job": {
      "@id": "databricks:jobs",
      "@context": {
        "job_id": {
          "@id": "databricks:jobs#job_id",
          "@type": "xsd:long"
        },
        "creator_user_name": {
          "@id": "dcterms:creator",
          "@type": "xsd:string"
        },
        "run_as_user_name": {
          "@id": "databricks:jobs#run_as_user_name",
          "@type": "xsd:string"
        },
        "created_time": {
          "@id": "dcterms:created",
          "@type": "xsd:long"
        },
        "settings": {
          "@id": "databricks:jobs#settings",
          "@context": {
            "name": {
              "@id": "schema:name",
              "@type": "xsd:string"
            },
            "tags": {
              "@id": "databricks:jobs#tags",
              "@type": "@json"
            },
            "tasks": {
              "@id": "databricks:jobs#tasks",
              "@container": "@list"
            },
            "schedule": {
              "@id": "databricks:jobs#schedule",
              "@context": {
                "quartz_cron_expression": {
                  "@id": "databricks:jobs#quartz_cron_expression",
                  "@type": "xsd:string"
                },
                "timezone_id": {
                  "@id": "databricks:jobs#timezone_id",
                  "@type": "xsd:string"
                },
                "pause_status": {
                  "@id": "databricks:jobs#pause_status",
                  "@type": "xsd:string"
                }
              }
            },
            "max_concurrent_runs": {
              "@id": "databricks:jobs#max_concurrent_runs",
              "@type": "xsd:integer"
            },
            "timeout_seconds": {
              "@id": "databricks:jobs#timeout_seconds",
              "@type": "xsd:integer"
            },
            "format": {
              "@id": "databricks:jobs#format",
              "@type": "xsd:string"
            },
            "git_source": {
              "@id": "databricks:jobs#git_source",
              "@context": {
                "git_url": {
                  "@id": "schema:codeRepository",
                  "@type": "xsd:anyURI"
                },
                "git_provider": {
                  "@id": "databricks:jobs#git_provider",
                  "@type": "xsd:string"
                },
                "git_branch": {
                  "@id": "databricks:jobs#git_branch",
                  "@type": "xsd:string"
                },
                "git_tag": {
                  "@id": "databricks:jobs#git_tag",
                  "@type": "xsd:string"
                },
                "git_commit": {
                  "@id": "databricks:jobs#git_commit",
                  "@type": "xsd:string"
                }
              }
            }
          }
        }
      }
    },

    "TaskSettings": {
      "@id": "databricks:jobs#task",
      "@context": {
        "task_key": {
          "@id": "databricks:jobs#task_key",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "depends_on": {
          "@id": "databricks:jobs#depends_on",
          "@container": "@list"
        },
        "existing_cluster_id": {
          "@id": "databricks:jobs#existing_cluster_id",
          "@type": "xsd:string"
        },
        "job_cluster_key": {
          "@id": "databricks:jobs#job_cluster_key",
          "@type": "xsd:string"
        },
        "notebook_task": {
          "@id": "databricks:jobs#notebook_task",
          "@context": {
            "notebook_path": {
              "@id": "databricks:jobs#notebook_path",
              "@type": "xsd:string"
            },
            "source": {
              "@id": "databricks:jobs#source",
              "@type": "xsd:string"
            },
            "base_parameters": {
              "@id": "databricks:jobs#base_parameters",
              "@type": "@json"
            }
          }
        },
        "spark_jar_task": {
          "@id": "databricks:jobs#spark_jar_task"
        },
        "spark_python_task": {
          "@id": "databricks:jobs#spark_python_task"
        },
        "sql_task": {
          "@id": "databricks:jobs#sql_task"
        },
        "dbt_task": {
          "@id": "databricks:jobs#dbt_task"
        },
        "pipeline_task": {
          "@id": "databricks:jobs#pipeline_task"
        },
        "run_if": {
          "@id": "databricks:jobs#run_if",
          "@type": "xsd:string"
        },
        "timeout_seconds": {
          "@id": "databricks:jobs#task_timeout_seconds",
          "@type": "xsd:integer"
        },
        "max_retries": {
          "@id": "databricks:jobs#max_retries",
          "@type": "xsd:integer"
        },
        "libraries": {
          "@id": "databricks:jobs#libraries",
          "@container": "@list"
        }
      }
    },

    "Run": {
      "@id": "databricks:jobs#run",
      "@context": {
        "run_id": {
          "@id": "databricks:jobs#run_id",
          "@type": "xsd:long"
        },
        "run_name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "job_id": {
          "@id": "databricks:jobs#job_id",
          "@type": "xsd:long"
        },
        "number_in_job": {
          "@id": "databricks:jobs#number_in_job",
          "@type": "xsd:long"
        },
        "state": {
          "@id": "databricks:jobs#run_state",
          "@context": {
            "life_cycle_state": {
              "@id": "databricks:jobs#life_cycle_state",
              "@type": "xsd:string"
            },
            "result_state": {
              "@id": "databricks:jobs#result_state",
              "@type": "xsd:string"
            },
            "state_message": {
              "@id": "databricks:jobs#state_message",
              "@type": "xsd:string"
            }
          }
        },
        "start_time": {
          "@id": "databricks:jobs#run_start_time",
          "@type": "xsd:long"
        },
        "end_time": {
          "@id": "databricks:jobs#run_end_time",
          "@type": "xsd:long"
        },
        "setup_duration": {
          "@id": "databricks:jobs#setup_duration",
          "@type": "xsd:long"
        },
        "execution_duration": {
          "@id": "databricks:jobs#execution_duration",
          "@type": "xsd:long"
        },
        "cleanup_duration": {
          "@id": "databricks:jobs#cleanup_duration",
          "@type": "xsd:long"
        },
        "run_type": {
          "@id": "databricks:jobs#run_type",
          "@type": "xsd:string"
        },
        "run_page_url": {
          "@id": "schema:url",
          "@type": "xsd:anyURI"
        },
        "trigger": {
          "@id": "databricks:jobs#trigger",
          "@type": "xsd:string"
        },
        "creator_user_name": {
          "@id": "dcterms:creator",
          "@type": "xsd:string"
        }
      }
    },

    "WorkspaceObject": {
      "@id": "databricks:workspace",
      "@context": {
        "object_type": {
          "@id": "databricks:workspace#object_type",
          "@type": "xsd:string"
        },
        "path": {
          "@id": "databricks:workspace#path",
          "@type": "xsd:string"
        },
        "language": {
          "@id": "schema:programmingLanguage",
          "@type": "xsd:string"
        },
        "object_id": {
          "@id": "databricks:workspace#object_id",
          "@type": "xsd:long"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:long"
        },
        "modified_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:long"
        },
        "size": {
          "@id": "schema:contentSize",
          "@type": "xsd:long"
        }
      }
    },

    "Library": {
      "@id": "databricks:libraries",
      "@context": {
        "jar": {
          "@id": "databricks:libraries#jar",
          "@type": "xsd:anyURI"
        },
        "whl": {
          "@id": "databricks:libraries#whl",
          "@type": "xsd:anyURI"
        },
        "pypi": {
          "@id": "databricks:libraries#pypi",
          "@context": {
            "package": {
              "@id": "schema:name",
              "@type": "xsd:string"
            },
            "repo": {
              "@id": "schema:codeRepository",
              "@type": "xsd:anyURI"
            }
          }
        },
        "maven": {
          "@id": "databricks:libraries#maven",
          "@context": {
            "coordinates": {
              "@id": "databricks:libraries#maven_coordinates",
              "@type": "xsd:string"
            },
            "repo": {
              "@id": "schema:codeRepository",
              "@type": "xsd:anyURI"
            },
            "exclusions": {
              "@id": "databricks:libraries#maven_exclusions",
              "@container": "@list"
            }
          }
        },
        "cran": {
          "@id": "databricks:libraries#cran",
          "@context": {
            "package": {
              "@id": "schema:name",
              "@type": "xsd:string"
            },
            "repo": {
              "@id": "schema:codeRepository",
              "@type": "xsd:anyURI"
            }
          }
        }
      }
    },

    "AutoScale": {
      "@id": "databricks:clusters#autoscale",
      "@context": {
        "min_workers": {
          "@id": "databricks:clusters#min_workers",
          "@type": "xsd:integer"
        },
        "max_workers": {
          "@id": "databricks:clusters#max_workers",
          "@type": "xsd:integer"
        }
      }
    },

    "CronSchedule": {
      "@id": "databricks:jobs#schedule",
      "@context": {
        "quartz_cron_expression": {
          "@id": "databricks:jobs#quartz_cron_expression",
          "@type": "xsd:string"
        },
        "timezone_id": {
          "@id": "databricks:jobs#timezone_id",
          "@type": "xsd:string"
        },
        "pause_status": {
          "@id": "databricks:jobs#pause_status",
          "@type": "xsd:string"
        }
      }
    },

    "ErrorResponse": {
      "@id": "databricks:errors",
      "@context": {
        "error_code": {
          "@id": "databricks:errors#error_code",
          "@type": "xsd:string"
        },
        "message": {
          "@id": "databricks:errors#message",
          "@type": "xsd:string"
        }
      }
    }
  }
}
